<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:scaleType="fillCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottomControls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:flow_verticalBias="0"/>

    <com.connect.medium.ui.main.fragments.create.CropOverlayView
        android:id="@+id/cropOverlay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layerType="software"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView" />

    <!-- Close button -->
    <ImageButton
        android:id="@+id/btnClose"
        style="?attr/borderlessButtonStyle"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:padding="10dp"
        android:src="@drawable/ic_close"
        android:background="@drawable/bg_camera_overlay_btn"
        app:backgroundTint="@null"
        android:contentDescription="Close"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:tint="#FFFFFF" />

    <!-- Flip camera button -->
    <ImageButton
        android:id="@+id/btnFlipCamera"
        style="?attr/borderlessButtonStyle"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        android:padding="10dp"
        android:src="@drawable/ic_flip_camera"
        android:background="@drawable/bg_camera_overlay_btn"
        app:backgroundTint="@null"
        android:contentDescription="Flip camera"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:tint="#FFFFFF" />

    <!-- Recording indicator -->
    <LinearLayout
        android:id="@+id/tvRecordingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:background="#73000000"
        android:backgroundTint="#73000000"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_rec_dot" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REC"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/purple_800"
        android:paddingTop="16dp"
        android:paddingBottom="32dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@+id/previewView"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabMode"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_tab_pill"
            app:tabBackground="@android:color/transparent"
            app:tabGravity="fill"
            app:tabIndicatorColor="#FFFFFF"
            app:tabIndicatorHeight="0dp"
            app:tabMode="fixed"
            app:tabRippleColor="@android:color/transparent"
            app:tabSelectedTextColor="@color/foreground"
            app:tabTextColor="@color/muted"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/btnCapture"
            android:layout_marginBottom="16dp"
            app:layout_constraintWidth_max="220dp"
            app:layout_constraintWidth_percent="0.55">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHOTO" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VIDEO" />

        </com.google.android.material.tabs.TabLayout>

        <View
            android:id="@+id/btnCapture"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_capture_btn_idle"
            android:clickable="true"
            android:contentDescription="Capture"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:layout_constraintTop_toBottomOf="@id/tabMode"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintWidth_percent="0.20"
            app:layout_constraintWidth_min="64dp"
            app:layout_constraintWidth_max="96dp" />

        <ImageButton
            android:id="@+id/btnGallery"
            style="?attr/borderlessButtonStyle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="8dp"
            android:src="@drawable/ic_gallery"
            android:background="@drawable/bg_camera_overlay_btn"
            app:backgroundTint="@null"
            android:contentDescription="Open gallery"
            app:tint="#FFFFFF"
            app:layout_constraintTop_toTopOf="@id/btnCapture"
            app:layout_constraintBottom_toBottomOf="@id/btnCapture"
            app:layout_constraintEnd_toStartOf="@id/btnCapture"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintHorizontal_bias="0.5" />

        <ImageButton
            android:id="@+id/btnFlash"
            style="?attr/borderlessButtonStyle"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="8dp"
            android:src="@drawable/ic_flash_auto"
            android:background="@drawable/bg_camera_overlay_btn"
            app:backgroundTint="@null"
            android:contentDescription="Toggle flash"
            app:tint="#FFFFFF"
            app:layout_constraintTop_toTopOf="@id/btnCapture"
            app:layout_constraintBottom_toBottomOf="@id/btnCapture"
            app:layout_constraintStart_toEndOf="@id/btnCapture"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>