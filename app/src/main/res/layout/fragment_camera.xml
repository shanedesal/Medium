<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:scaleType="fillCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintDimensionRatio="H,1:1" />

    <!-- Close button -->
    <ImageButton
        android:id="@+id/btnClose"
        style="?attr/borderlessButtonStyle"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:padding="10dp"
        android:src="@drawable/ic_close"
        android:tint="#FFFFFF"
        android:background="@drawable/bg_camera_overlay_btn"
        android:contentDescription="Close"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView" />

    <!-- Flip camera button -->
    <ImageButton
        android:id="@+id/btnFlipCamera"
        style="?attr/borderlessButtonStyle"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="8dp"
        android:padding="10dp"
        android:src="@drawable/ic_flip_camera"
        android:tint="#FFFFFF"
        android:background="@drawable/bg_camera_overlay_btn"
        android:contentDescription="Flip camera"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView" />

    <!-- Recording indicator -->
    <LinearLayout
        android:id="@+id/tvRecordingIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:background="#73000000"
        android:backgroundTint="#73000000"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_rec_dot" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="REC"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

    </LinearLayout>

    <!-- Bottom controls -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="28dp"
        android:background="#111111"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/previewView">

        <!-- Photo / Video toggle -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabMode"
            android:layout_width="200dp"
            android:layout_height="36dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_tab_pill"
            app:tabBackground="@android:color/transparent"
            app:tabGravity="fill"
            app:tabIndicatorColor="#FFFFFF"
            app:tabIndicatorHeight="0dp"
            app:tabMode="fixed"
            app:tabRippleColor="@android:color/transparent"
            app:tabSelectedTextColor="#000000"
            app:tabTextColor="#80FFFFFF">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PHOTO" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VIDEO" />

        </com.google.android.material.tabs.TabLayout>

        <!-- Shutter / record button -->
        <View
            android:id="@+id/btnCapture"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_capture_btn_idle"
            android:clickable="true"
            android:contentDescription="Capture"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>